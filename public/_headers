# Cache policy for static assets (Cloudflare Workers Static Assets honors this file).
#
# /assets/* files are content-hashed by Vite, so they can be cached forever —
# a new deploy produces new filenames, never a stale hit.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images and PDFs aren't hashed; cache for a day, revalidate cheaply after.
/images/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/pdfs/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/favicon.svg
  Cache-Control: public, max-age=86400
